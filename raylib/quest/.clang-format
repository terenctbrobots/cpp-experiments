SortIncludes: CaseSensitive
IncludeBlocks: Regroup
IncludeCategories:
  - Regex:           '^"(.*)\.(h|hpp)"'
    Priority:        1
  - Regex:           '^<extern/(.*)>'
    Priority:        2
  - Regex:           '^<(.*)>'
    Priority:        2
# Tell Clang-Format to place opening braces on a new line for everything
BreakBeforeBraces: Allman
IndentWidth: 4
AccessModifierOffset: 0
TabWidth: 4
UseTab: Never
# Set the maximum line length before Clang-Format forces a wrap
ColumnLimit: 120
NamespaceIndentation: All
# Keep standard pointers/references AND rvalue references locked to the type
PointerAlignment: Left
ReferenceAlignment: Left
# --- Force One-Liners Onto Separate Lines ---

# Forces function definitions onto multiple lines
AllowShortFunctionsOnASingleLine: None

# Forces 'if', 'else', 'while', and 'for' statements onto multiple lines
AllowShortBlocksOnASingleLine: false
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false

# Forces lambdas onto multiple lines
AllowShortLambdasOnASingleLine: None

# Forces namespaces onto multiple lines
AllowShortNamespacesOnASingleLine: false

# Forces enum declarations onto multiple lines
AllowShortEnumsOnASingleLine: false